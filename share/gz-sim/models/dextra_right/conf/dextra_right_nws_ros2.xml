<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE robot PUBLIC "-//YARP//DTD yarprobotinterface 3.0//EN" "http://www.yarp.it/DTD/yarprobotinterfaceV3.0.dtd">

<robot name="dextra_right_nws_ros2" portprefix="teoSim" build="0" xmlns:xi="http://www.w3.org/2001/XInclude">
    <devices>
        <device name="dextra_right_nws_ros2" type="controlBoard_nws_ros2">
            <param name="node_name">${portprefix}_rightHand</param>
            <param name="topic_name">/${portprefix}/rightHand/state</param>
            <param name="msgs_name">/${portprefix}/rightHand</param>
            <param name="period">0.01</param>
            <action phase="startup" level="5" type="attach">
