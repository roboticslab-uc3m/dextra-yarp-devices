<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE robot PUBLIC "-//YARP//DTD yarprobotinterface 3.0//EN" "http://www.yarp.it/DTD/yarprobotinterfaceV3.0.dtd">

<robot name="dextra_right_nws_yarp" portprefix="/teoSim" build="0" xmlns:xi="http://www.w3.org/2001/XInclude">
    <devices>
        <device name="dextra_right_nws_yarp" type="controlBoard_nws_yarp">
            <param name="name">${portprefix}/rightHand</param>
            <param name="period">0.01</param>
            <action phase="startup" level="5" type="attach">
                <param name="device">controlBoard_dextra_right</param>
            </action>
            <action phase="shutdown" level="5" type="detach" />
        </device>
        <device name="dextra_right_robotDescription_nws" type="robotDescription_nws_yarp">
            <param name="local">${portprefix}/rightHand/devices/rpc</param>
            <action phase="startup" level="5" type="attach">
                <param name="device">yriDescriptionStorage_right</param>
            </action>
            <action phase="shutdown" level="5" type="detach" />
        </device>
    </devices>
</robot>
